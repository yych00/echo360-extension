{
    "manifest_version": 3,
    "name": "Echo360 CC 字幕助手",
    "version": "1.0.0",
    "author": "yuchenyang",
    "description": "为 Echo360 视频课程自动加载 CC 字幕，并提供实时中文翻译显示。",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": false
    },
    "action": {
        "default_popup": "options.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png"
        }
    },
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "*://echo360.net.au/*",
        "*://canvas.lms.unimelb.edu.au/*",
        "*://translate.googleapis.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "*://echo360.net.au/*",
                "*://canvas.lms.unimelb.edu.au/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "inject.js",
                "defaults.json"
            ],
            "matches": [
                "*://echo360.net.au/*",
                "*://canvas.lms.unimelb.edu.au/*"
            ]
        }
    ]
}